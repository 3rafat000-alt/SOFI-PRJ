          "expr": "histogram_quantile(0.95, sum(rate(horizon_job_processed_duration_seconds_bucket[5m])) by (le, queue))",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Failed Jobs",
      "type": "stat",
      "description": "Number of failed jobs in last 5 minutes",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 18 },
