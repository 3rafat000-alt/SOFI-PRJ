# ─────────────────────────────────────────────────────────
# 🏗️ إعدادات التطبيق — Application Configuration
# ─────────────────────────────────────────────────────────
APP_NAME="صَكّ | SAKK Wallet"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000
# When true AND APP_ENV is local/testing, test wallet credit/debit endpoints
# are registered. Never enable in production.
APP_TEST_MODE_ENABLED=true

# ─────────────────────────────────────────────────────────
# 🔗 رابط الدفع — Payment Link
#    الرابط الأساسي لطلبات الدفع — رابط عميق مباشر للتطبيق
#    مسح / نقر sakk://pay/{uuid} يفتح التطبيق على شاشة الدفع
# ─────────────────────────────────────────────────────────
PAY_URL_BASE=sakk://pay

# ─────────────────────────────────────────────────────────
# 🌐 إعدادات اللغة والموقع — Locale Settings
# ─────────────────────────────────────────────────────────
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

# ─────────────────────────────────────────────────────────
# 🛠️ إعدادات الصيانة — Maintenance & Performance
# ─────────────────────────────────────────────────────────
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ─────────────────────────────────────────────────────────
# 📝 إعدادات السجلات — Logging
# ─────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────
# 🗄️ قاعدة البيانات — Database
#    اختر sqlite (افتراضي) أو mysql
# ─────────────────────────────────────────────────────────
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=carda_wallet
# DB_USERNAME=root
# DB_PASSWORD=

# ─────────────────────────────────────────────────────────
# 🔐 الجلسات — Session Configuration
# ─────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Send the session cookie only over HTTPS. Leave false for local HTTP dev.
# PRODUCTION BEHIND HTTPS MUST SET THIS TO true — otherwise the session
# cookie is sent in the clear and can be captured by network-level attackers.
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ─────────────────────────────────────────────────────────
# 📡 البث — Broadcasting
# ─────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ─────────────────────────────────────────────────────────
# 💾 نظام الملفات — Filesystem
# ─────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ─────────────────────────────────────────────────────────
# ⏳ الطوابير — Queue
# ─────────────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ─────────────────────────────────────────────────────────
# ⚡ التخزين المؤقت — Cache
# ─────────────────────────────────────────────────────────
CACHE_STORE=database
# CACHE_PREFIX=

# ─────────────────────────────────────────────────────────
# 🧠 Memcached
# ─────────────────────────────────────────────────────────
MEMCACHED_HOST=127.0.0.1

# ─────────────────────────────────────────────────────────
# 🔴 Redis
# ─────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────
# ✉️ البريد الإلكتروني — Mail
# ─────────────────────────────────────────────────────────
# Outgoing mail — Hostinger SMTP (info@zanjour.com)
# Port 465 = implicit SSL (MAIL_SCHEME=smtps). Alt: port 587 + MAIL_SCHEME=smtp (STARTTLS).
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=info@zanjour.com
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="info@zanjour.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────
# ☁️ AWS S3
# ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─────────────────────────────────────────────────────────
# ⚛️ Vite
# ─────────────────────────────────────────────────────────
VITE_APP_NAME="صَكّ | SAKK Wallet"

# ─────────────────────────────────────────────────────────
# 💳 مزود البطاقة — Card Provider
#    اختر: stripe | marqeta | other
# ─────────────────────────────────────────────────────────
CARD_PROVIDER=other
MARQETA_API_KEY=
MARQETA_API_SECRET=
MARQETA_ENVIRONMENT=sandbox

# ─────────────────────────────────────────────────────────
# 💳 Stripe — Card Issuing & Payment Processing
#    STRIPE_KEY   = publishable key (frontend, pk_...)
#    STRIPE_SECRET = secret key (backend, sk_...)
#    STRIPE_WEBHOOK_SECRET = webhook signing secret (whsec_...)
#    Get these from https://dashboard.stripe.com/apikeys
# ─────────────────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────
# 💰 إعدادات CCPayment — CCPayment Configuration
# ─────────────────────────────────────────────────────────
CCPAYMENT_APP_ID=your-app-id-here
CCPAYMENT_APP_SECRET=your-app-secret-here
# CCPayment sends webhooks from this IP — keep it whitelisted (comma-separated for more).
CCPAYMENT_IP_WHITELIST=127.0.0.1,54.150.123.157
CCPAYMENT_DEBUG_MODE=false
# Public base for CCPayment callback URLs — decoupled from APP_URL so webhooks hit the
# live reachable host while branded app URLs stay on sakk.app.
CCPAYMENT_WEBHOOK_BASE=https://sakk.zanjour.com

# ─────────────────────────────────────────────────────────
# 📱 WhatsApp OTP — OpenWA gateway (phone verification delivery)
# Self-hosted gateway: https://github.com/rmyndharis/OpenWA (docker, port 2785)
# ─────────────────────────────────────────────────────────
WHATSAPP_OTP_ENABLED=false
OPENWA_BASE_URL=http://127.0.0.1:2785
OPENWA_API_KEY=your-openwa-master-api-key
OPENWA_SESSION_ID=sakk-otp
# Country code prepended to local-format numbers (Syria = 963).
WHATSAPP_DEFAULT_COUNTRY=963
OPENWA_TIMEOUT=15

# ─────────────────────────────────────────────────────────
# ✈️ Telegram OTP — second delivery channel (account-linked, preferred when set)
# Create a bot via @BotFather → get the FULL token `<bot_id>:<hash>`.
# After setting the token, register the webhook: php artisan telegram:setup
# ─────────────────────────────────────────────────────────
TELEGRAM_OTP_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Any random string; Telegram echoes it back in X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_TIMEOUT=15

# ─────────────────────────────────────────────────────────
# ✈️ Telegram Gateway — auto-detect OTP by phone (NO linking, PAID)
# Detects whether a number has Telegram (checkSendAbility) and delivers the
# code straight to it. Token from https://gateway.telegram.org (separate from
# the bot token; billed per number). This is the "send to Telegram if the user
# has it, else WhatsApp" channel. https://core.telegram.org/gateway/api
# ─────────────────────────────────────────────────────────
TELEGRAM_GATEWAY_ENABLED=false
TELEGRAM_GATEWAY_TOKEN=
TELEGRAM_GATEWAY_TTL=600

# ─────────────────────────────────────────────────────────
# 🛟 Telegram SUPPORT bot (@SakkSupportBot) — two-way ticket bridge
# SEPARATE bot/token from the OTP bot. Users message it → a support ticket is
# opened; agent replies are pushed back. After setting the token:
#   php artisan telegram:support-setup
# ─────────────────────────────────────────────────────────
TELEGRAM_SUPPORT_ENABLED=false
TELEGRAM_SUPPORT_BOT_TOKEN=
TELEGRAM_SUPPORT_BOT_USERNAME=
TELEGRAM_SUPPORT_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────
# 💬 SMS OTP — final fallback (provider-agnostic HTTP gateway). "soon"
# Plug any provider that takes POST {to,text,from}. Disabled until configured.
# ─────────────────────────────────────────────────────────
SMS_OTP_ENABLED=false
SMS_ENDPOINT=
SMS_TOKEN=
SMS_SENDER=SAKK

# ─────────────────────────────────────────────────────────
# 🔔 Firebase Cloud Messaging — push notifications (HTTP v1 API)
#    FCM_SERVICE_ACCOUNT_FILE = path to Firebase service account JSON
#    FCM_PROJECT_ID           = Firebase project ID (auto-detected from SA if omitted)
#    Google Cloud Console → IAM & Admin → Service Accounts → create/Download JSON
#    OAuth2 JWT-bearer RS256-signed via openssl. Legacy fcm/send shutdown June 2024.
# ─────────────────────────────────────────────────────────
FCM_SERVICE_ACCOUNT_FILE=
FCM_PROJECT_ID=

# ─────────────────────────────────────────────────────────
# 🛡️ Laravel Sanctum — المصادقة API
# ─────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost
SANCTUM_TOKEN_PREFIX=

# ─────────────────────────────────────────────────────────
# 🗺️ Google Maps — admin agent location picker (Maps JavaScript API + Places)
# Google Cloud Console → enable "Maps JavaScript API" + "Places API",
# create an API key, enable billing, then RESTRICT the key by HTTP referrer
# (e.g. sakk.local/* and your production admin domain). Browser-exposed key.
# ─────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────
# 🔐 External App Token — M2M auth for TaskSync Pro / external services.
# ExternalAppToken middleware validates this against Authorization: Bearer.
# The service user (tasksync@sakk.com) is created by ServiceUserSeeder.
# ─────────────────────────────────────────────────────────
SAKK_APP_TOKEN=
SAKK_SERVICE_USER_EMAIL=tasksync@sakk.com

# ─────────────────────────────────────────────────────────
# 🥇 Gold spot price — automatic per-karat pricing (gold:update-prices, hourly)
# Provider 'gold-api' (api.gold-api.com) is FREE and needs no key — leave as-is.
# Provider 'goldapi' (goldapi.io) is more robust but requires GOLDAPI_KEY.
# Toggle on/off + margin% live in the admin panel (الذهب › أسعار الذهب).
# ─────────────────────────────────────────────────────────
GOLD_PRICE_PROVIDER=gold-api
GOLDAPI_KEY=
GOLD_PRICE_TIMEOUT=15
