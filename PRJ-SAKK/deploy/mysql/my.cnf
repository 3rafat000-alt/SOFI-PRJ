# MySQL / MariaDB hardening config for SAKK production
# Deploy: copy to /etc/mysql/conf.d/sakk-hardening.cnf
# Requires: mysqld restart after deploy

[mysqld]
# ── Network binding — service-level isolation ──────────────────────────────
# Belt-and-suspenders with iptables: even if firewall rules are flushed,
# mysqld will not accept connections from non-loopback addresses.
bind-address            = 127.0.0.1

# ── Performance / safety ──────────────────────────────────────────────────
# Avoid DNS lookups on every connection — prevents slow auth on missing PTR
skip-name-resolve

# Disable LOAD DATA LOCAL INFILE — prevents client-side file read via SQL
local-infile            = 0

# ── Character set defaults ────────────────────────────────────────────────
character-set-server    = utf8mb4
collation-server        = utf8mb4_unicode_ci

# ── Logging ───────────────────────────────────────────────────────────────
# General query log off in production (I/O cost); slow-query log on
general_log             = 0
slow_query_log          = 1
slow_query_log_file     = /var/log/mysql/slow.log
long_query_time         = 2

# ── Strict mode ───────────────────────────────────────────────────────────
# Prevent silent data truncation / implicit type coercion
sql_mode                = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

[mysql]
# Match client charset to server
default-character-set   = utf8mb4

[client]
default-character-set   = utf8mb4
